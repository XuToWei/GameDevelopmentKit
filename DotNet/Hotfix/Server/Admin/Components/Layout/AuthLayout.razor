@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<main class="auth-shell">
    @Body
</main>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#6D5DFB",
            Secondary = "#0891B2",
            Tertiary = "#F59E0B",
            Success = "#12B76A",
            Info = "#0EA5E9",
            Warning = "#F79009",
            Error = "#F04438",
            Background = "#F4F6FB",
            Surface = "#FFFFFF",
            TextPrimary = "#101828",
            TextSecondary = "#667085",
        },
    };
}
