@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="admin-layout">
    <MudAppBar Elevation="0" Class="admin-topbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" Class="menu-button" />
        <div class="brand-lockup">
            <div class="brand-mark">
                <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Size="Size.Medium" />
            </div>
            <div class="brand-copy">
                <span class="brand-name">GDK Console</span>
                <span class="brand-subtitle">Game Operations</span>
            </div>
        </div>
        <MudSpacer />
        <div class="runtime-pill">
            <span class="live-dot"></span>
            @Options.Instance.StartConfig
        </div>
        <MudTooltip Text="@(_isDarkMode ? "切换浅色模式" : "切换深色模式")">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" OnClick="ToggleTheme" Class="topbar-icon" />
        </MudTooltip>
        @if (AuthService.CurrentUser != null)
        {
            <div class="user-summary">
                <MudAvatar Size="Size.Small" Class="user-avatar">@GetUserInitial()</MudAvatar>
                <div class="user-copy">
                    <span class="user-name">@AuthService.CurrentUser.Username</span>
                    <span class="user-role">@GetRoleLabel(AuthService.CurrentUser.Role)</span>
                </div>
            </div>
            <MudTooltip Text="退出登录">
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                               OnClick="HandleLogout" Class="topbar-icon" />
            </MudTooltip>
        }
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0"
               Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md" Width="272px"
               Class="admin-drawer">
        <NavMenu />
        <div class="drawer-footer">
            <div class="drawer-footer-icon"><MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Small" /></div>
            <div>
                <div class="drawer-footer-title">安全连接</div>
                <div class="drawer-footer-copy">ET Admin Channel</div>
            </div>
        </div>
    </MudDrawer>

    <MudMainContent Class="admin-main">
        <div class="page-container">
            @Body
        </div>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#6D5DFB",
            Secondary = "#0891B2",
            Tertiary = "#F59E0B",
            Success = "#12B76A",
            Info = "#0EA5E9",
            Warning = "#F79009",
            Error = "#F04438",
            Surface = "#FFFFFF",
            Background = "#F4F6FB",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#101828",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#344054",
            TextPrimary = "#101828",
            TextSecondary = "#667085",
            ActionDefault = "#667085",
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#8B7CFF",
            Secondary = "#22D3EE",
            Tertiary = "#FBBF24",
            Success = "#34D399",
            Info = "#38BDF8",
            Warning = "#FBBF24",
            Error = "#FB7185",
            Surface = "#121A2D",
            Background = "#0B1020",
            AppbarBackground = "#10172A",
            DrawerBackground = "#0F172A",
            DrawerText = "#CBD5E1",
            TextPrimary = "#F8FAFC",
            TextSecondary = "#94A3B8",
            ActionDefault = "#94A3B8",
        },
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
    }

    private async Task HandleLogout()
    {
        await JS.InvokeVoidAsync("gdkAdminAuth.logout");
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private string GetUserInitial()
    {
        var username = AuthService.CurrentUser.Username;
        return string.IsNullOrWhiteSpace(username) ? "A" : username[..1].ToUpperInvariant();
    }

    private static string GetRoleLabel(string role) => role switch
    {
        "SuperAdmin" => "超级管理员",
        "Operator" => "运维人员",
        "ReadOnly" => "只读成员",
        _ => role,
    };
}
