<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Routes).Assembly">
        <Found Context="routeData">
            @if (routeData.PageType == typeof(ET.Server.Admin.Components.Pages.Login))
            {
                <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.AuthLayout)" />
            }
            else
            {
                <AuthorizeView>
                    <Authorized>
                        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
                    </Authorized>
                    <NotAuthorized>
                        <RedirectToLogin />
                    </NotAuthorized>
                </AuthorizeView>
            }
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            <AuthorizeView>
                <Authorized>
                    <PageTitle>未找到页面</PageTitle>
                    <LayoutView Layout="typeof(Layout.MainLayout)">
                        <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height:60vh;">
                            <MudStack AlignItems="AlignItems.Center" Spacing="4">
                                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" />
                                <MudText Typo="Typo.h4">404 - 页面未找到</MudText>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">返回首页</MudButton>
                            </MudStack>
                        </MudContainer>
                    </LayoutView>
                </Authorized>
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
            </AuthorizeView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
