@page "/players"
@inject PlayerService PlayerService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>玩家管理 - 游戏管理后台</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">玩家管理</MudText>

<MudTable ServerData="LoadPlayers" Dense="true" Hover="true" Elevation="2" @ref="_table">
    <ToolBarContent>
        <MudTextField @bind-Value="_searchString" Placeholder="搜索玩家 ID / 名称..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" Immediate="false"
                      OnKeyDown="OnSearchKeyDown" Class="mt-0" />
        <MudSpacer />
        <MudSelect Value="_filterStatus" Label="状态" Variant="Variant.Outlined" Dense="true"
                   Margin="Margin.Dense" Style="width:120px;" Class="ml-2"
                   ValueChanged="@((string val) => { _filterStatus = val; _table.ReloadServerData(); })">
            <MudSelectItem T="string" Value="@("")">全部</MudSelectItem>
            <MudSelectItem T="string" Value="@("online")">在线</MudSelectItem>
            <MudSelectItem T="string" Value="@("offline")">离线</MudSelectItem>
            <MudSelectItem T="string" Value="@("banned")">已封禁</MudSelectItem>
        </MudSelect>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="PlayerInfo" SortLabel="id">ID</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="PlayerInfo" SortLabel="name">名称</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="PlayerInfo" SortLabel="level">等级</MudTableSortLabel></MudTh>
        <MudTh>状态</MudTh>
        <MudTh>服务器</MudTh>
        <MudTh><MudTableSortLabel T="PlayerInfo" SortLabel="lastLogin">最后登录</MudTableSortLabel></MudTh>
        <MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="名称">
            <MudLink Href="@($"/players/{context.Id}")">@context.Name</MudLink>
        </MudTd>
        <MudTd DataLabel="等级">@context.Level</MudTd>
        <MudTd DataLabel="状态">
            @if (context.IsBanned)
            {
                <MudChip T="string" Color="Color.Error" Size="Size.Small" Class="status-chip">已封禁</MudChip>
            }
            else if (context.IsOnline)
            {
                <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="status-chip">在线</MudChip>
            }
            else
            {
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Class="status-chip">离线</MudChip>
            }
        </MudTd>
        <MudTd DataLabel="服务器">
            @if (context.IsOnline && context.CurrentServerId != 0)
            {
                <MudLink Href="@($"/servers/{context.CurrentServerId}")">Server-@context.CurrentServerId</MudLink>
            }
            else
            {
                <MudText Typo="Typo.body2">-</MudText>
            }
        </MudTd>
        <MudTd DataLabel="最后登录">@context.LastLoginTime.ToString("yyyy-MM-dd HH:mm")</MudTd>
        <MudTd DataLabel="操作">
            @if (context.IsOnline)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Warning" Size="Size.Small"
                               OnClick="@(() => KickPlayer(context))" />
            }
            @if (context.IsBanned)
            {
                <MudIconButton Icon="@Icons.Material.Filled.LockOpen" Color="Color.Success" Size="Size.Small"
                               OnClick="@(() => UnbanPlayer(context))" />
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.Block" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => BanPlayer(context))" />
            }
            <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Size="Size.Small"
                           Href="@($"/players/{context.Id}")" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>暂无玩家数据（玩家数据将在 ET 服务器运行时自动采集）</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<PlayerInfo> _table = null!;
    private string _searchString = "";
    private string _filterStatus = "";

    private Task<TableData<PlayerInfo>> LoadPlayers(TableState state, CancellationToken ct)
    {
        var sortBy = state.SortLabel;
        var ascending = state.SortDirection == SortDirection.Ascending;

        var items = PlayerService.GetPlayers(_searchString, _filterStatus,
            state.Page, state.PageSize, sortBy, ascending);
        var totalItems = PlayerService.GetPlayerCount(_searchString, _filterStatus);

        return Task.FromResult(new TableData<PlayerInfo> { TotalItems = totalItems, Items = items });
    }

    private void OnSearchKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            _table.ReloadServerData();
        }
    }

    private async Task KickPlayer(PlayerInfo player)
    {
        var confirm = await DialogService.ShowMessageBox("踢出玩家", $"确定要将 {player.Name} 踢出服务器吗？", "确定", "取消");
        if (confirm != true) return;
        var success = await PlayerService.KickPlayerAsync(player.Id);
        Snackbar.Add(success ? $"已将 {player.Name} 踢出服务器" : "操作失败", success ? Severity.Warning : Severity.Error);
        await _table.ReloadServerData();
    }

    private async Task BanPlayer(PlayerInfo player)
    {
        var confirm = await DialogService.ShowMessageBox("封禁玩家", $"确定要封禁 {player.Name} 吗？（7天）", "确定", "取消");
        if (confirm != true) return;
        var success = await PlayerService.BanPlayerAsync(player.Id, "管理员手动封禁", DateTime.UtcNow.AddDays(7));
        Snackbar.Add(success ? $"已封禁 {player.Name}（7天）" : "操作失败", success ? Severity.Error : Severity.Error);
        await _table.ReloadServerData();
    }

    private async Task UnbanPlayer(PlayerInfo player)
    {
        var success = PlayerService.UnbanPlayer(player.Id);
        Snackbar.Add(success ? $"已解封 {player.Name}" : "操作失败", success ? Severity.Success : Severity.Error);
        await _table.ReloadServerData();
    }
}
