@page "/logs"
@inject LogService LogService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>日志查看器 - 游戏管理后台</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h5">日志查看器</MudText>
    <MudStack Row="true" Spacing="2">
        <MudSwitch @bind-Value="_autoRefresh" Color="Color.Primary" Label="自动刷新" T="bool" />
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshLogs">刷新</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearLogs">清除</MudButton>
    </MudStack>
</MudStack>

@* 筛选条件 *@
<MudPaper Elevation="2" Class="pa-3 mb-4">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="4">
            <MudTextField @bind-Value="_searchString" Label="搜索关键词" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudSelect @bind-Value="_filterLevel" Label="日志级别" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                <MudSelectItem T="string" Value="@("")">全部</MudSelectItem>
                <MudSelectItem T="string" Value="@("DEBUG")">DEBUG</MudSelectItem>
                <MudSelectItem T="string" Value="@("INFO")">INFO</MudSelectItem>
                <MudSelectItem T="string" Value="@("WARN")">WARN</MudSelectItem>
                <MudSelectItem T="string" Value="@("ERROR")">ERROR</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudSelect @bind-Value="_filterServer" Label="服务器" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                <MudSelectItem T="string" Value="@("")">全部</MudSelectItem>
                @foreach (var server in _serverNames)
                {
                    <MudSelectItem T="string" Value="@server">@server</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="align-self-center">
                    @_logs.Count / @LogService.TotalCount 条
                </MudText>
                <MudSpacer />
                @foreach (var kv in _levelCounts)
                {
                    <MudChip T="string" Size="Size.Small" Color="@GetLevelColor(kv.Key)" Variant="Variant.Outlined"
                             OnClick="@(() => _filterLevel = _filterLevel == kv.Key ? "" : kv.Key)">
                        @kv.Key: @kv.Value
                    </MudChip>
                }
            </MudStack>
        </MudItem>
    </MudGrid>
</MudPaper>

@* 日志内容 *@
<MudPaper Elevation="2" Class="pa-0" Style="background: #0d1117;">
    <div class="log-container pa-3" style="max-height:calc(100vh - 380px); min-height:400px;">
        @if (_logs.Any())
        {
            @foreach (var log in _logs)
            {
                <div style="color: @GetLevelTextColor(log.Level); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 2px 0;">
                    <span style="color: #6e7681;">@log.Timestamp.ToString("HH:mm:ss.fff")</span>
                    <span style="color: @GetLevelTextColor(log.Level); font-weight:bold; display:inline-block; width:50px;">[@log.Level]</span>
                    <span style="color: #7ee787;">[@log.Server]</span>
                    <span style="color: @GetLevelTextColor(log.Level);">@log.Message</span>
                </div>
            }
        }
        else
        {
            <div style="color: #6e7681; text-align: center; padding: 40px;">
                @if (LogService.TotalCount == 0)
                {
                    <span>暂无日志。启动服务器进程后，进程输出将自动显示在此处。</span>
                }
                else
                {
                    <span>没有匹配当前筛选条件的日志</span>
                }
            </div>
        }
    </div>
</MudPaper>

@code {
    private string _searchString = "";
    private string _filterLevel = "";
    private string _filterServer = "";
    private bool _autoRefresh = true;
    private System.Threading.Timer _refreshTimer;

    private List<LogService.LogEntry> _logs = new();
    private List<string> _serverNames = new();
    private Dictionary<string, int> _levelCounts = new();

    protected override void OnInitialized()
    {
        RefreshLogs();
        LogService.OnNewLog += OnNewLog;
        _refreshTimer = new Timer(_ => InvokeAsync(RefreshIfAuto), null, 2000, 2000);
    }

    private void RefreshIfAuto()
    {
        if (_autoRefresh)
        {
            RefreshLogs();
            StateHasChanged();
        }
    }

    private void OnNewLog()
    {
        if (_autoRefresh)
        {
            InvokeAsync(() =>
            {
                RefreshLogs();
                StateHasChanged();
            });
        }
    }

    private void RefreshLogs()
    {
        _logs = LogService.GetLogs(
            string.IsNullOrEmpty(_filterLevel) ? null : _filterLevel,
            string.IsNullOrEmpty(_filterServer) ? null : _filterServer,
            string.IsNullOrWhiteSpace(_searchString) ? null : _searchString);
        _levelCounts = LogService.GetLevelCounts();
        _serverNames = LogService.GetServerNames();
    }

    private void ClearLogs()
    {
        LogService.Clear();
        RefreshLogs();
        Snackbar.Add("日志已清除", Severity.Info);
    }

    private Color GetLevelColor(string level) => level switch
    {
        "DEBUG" => Color.Default,
        "INFO" => Color.Info,
        "WARN" => Color.Warning,
        "ERROR" => Color.Error,
        _ => Color.Default,
    };

    private string GetLevelTextColor(string level) => level switch
    {
        "DEBUG" => "#8b949e",
        "INFO" => "#58a6ff",
        "WARN" => "#d29922",
        "ERROR" => "#f85149",
        _ => "#c9d1d9",
    };

    public void Dispose()
    {
        LogService.OnNewLog -= OnNewLog;
        _refreshTimer?.Dispose();
    }
}
