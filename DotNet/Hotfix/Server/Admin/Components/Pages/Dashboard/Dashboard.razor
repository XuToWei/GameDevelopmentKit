@page "/"
@inject ServerMonitorService MonitorService
@inject ServerMonitorNotifier Notifier
@inject ProcessManagerService ProcessManager
@inject VersionService VersionService
@inject AgentActorService AgentService
@implements IDisposable

<PageTitle>仪表盘 - 游戏管理后台</PageTitle>

<section class="dashboard-hero">
    <div class="hero-content">
        <div class="page-kicker"><span class="live-dot"></span> LIVE OPERATIONS</div>
        <h1>运行态势</h1>
        <p>集中查看服务器、Agent 与在线玩家状态，快速进入高频运维流程。</p>
    </div>
    <div class="hero-side">
        <div class="system-health @GetSystemHealthClass()">
            <span class="health-orb"><span></span></span>
            <div>
                <strong>@GetSystemHealthText()</strong>
                <small>最近同步 @_lastUpdated.ToString("HH:mm:ss")</small>
            </div>
        </div>
        <MudButton Href="/servers" Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Dns" Class="hero-action">管理服务器</MudButton>
    </div>
</section>

<div class="metric-grid">
    <div class="metric-card metric-primary">
        <div class="metric-icon"><MudIcon Icon="@Icons.Material.Filled.Dns" /></div>
        <div class="metric-label">运行中服务器</div>
        <div class="metric-value">@_runningServers <span>/ @_totalServers</span></div>
        <div class="metric-foot">@(_totalServers == 0 ? "等待接入进程" : $"{Math.Round(_runningServers * 100d / _totalServers):F0}% 可用")</div>
    </div>
    <div class="metric-card metric-cyan">
        <div class="metric-icon"><MudIcon Icon="@Icons.Material.Filled.Groups" /></div>
        <div class="metric-label">在线玩家</div>
        <div class="metric-value">@_onlinePlayers</div>
        <div class="metric-foot">全服实时汇总</div>
    </div>
    <div class="metric-card metric-amber">
        <div class="metric-icon"><MudIcon Icon="@Icons.Material.Filled.CloudQueue" /></div>
        <div class="metric-label">在线 Agent</div>
        <div class="metric-value">@_onlineAgents <span>/ @_totalAgents</span></div>
        <div class="metric-foot">跨机器调度节点</div>
    </div>
    <div class="metric-card metric-green">
        <div class="metric-icon"><MudIcon Icon="@Icons.Material.Filled.RocketLaunch" /></div>
        <div class="metric-label">活跃版本</div>
        <div class="metric-value">@_activeVersionCount</div>
        <div class="metric-foot">生产环境已激活</div>
    </div>
    <div class="metric-card metric-neutral">
        <div class="metric-icon"><MudIcon Icon="@Icons.Material.Filled.Engineering" /></div>
        <div class="metric-label">维护模式</div>
        <div class="metric-value metric-text-value">@(ProcessManager.MaintenanceMode ? "已开启" : "未开启")</div>
        <div class="metric-foot">@(ProcessManager.MaintenanceMode ? "新连接当前受限" : "正常接受连接")</div>
    </div>
</div>

<div class="dashboard-grid">
    <section class="content-panel quick-panel">
        <div class="panel-header">
            <div>
                <div class="panel-eyebrow">SHORTCUTS</div>
                <h2>快捷操作</h2>
            </div>
            <span class="panel-hint">常用运维入口</span>
        </div>
        <div class="quick-action-grid">
            <a class="quick-action quick-violet" href="/servers">
                <span><MudIcon Icon="@Icons.Material.Filled.Dns" /></span>
                <div><strong>服务器</strong><small>启停与状态</small></div>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="quick-arrow" />
            </a>
            <a class="quick-action quick-cyan" href="/players">
                <span><MudIcon Icon="@Icons.Material.Filled.Groups" /></span>
                <div><strong>玩家</strong><small>查询与管控</small></div>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="quick-arrow" />
            </a>
            <a class="quick-action quick-amber" href="/hotreload">
                <span><MudIcon Icon="@Icons.Material.Filled.Bolt" /></span>
                <div><strong>热更新</strong><small>代码与配置</small></div>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="quick-arrow" />
            </a>
            <a class="quick-action quick-slate" href="/logs">
                <span><MudIcon Icon="@Icons.Material.Filled.Terminal" /></span>
                <div><strong>日志</strong><small>实时排障</small></div>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="quick-arrow" />
            </a>
        </div>
    </section>

    <section class="content-panel delivery-panel">
        <div class="panel-header">
            <div>
                <div class="panel-eyebrow">DELIVERY</div>
                <h2>交付中心</h2>
            </div>
        </div>
        <a href="/versions" class="delivery-row">
            <span class="delivery-icon"><MudIcon Icon="@Icons.Material.Filled.Inventory2" /></span>
            <div><strong>版本管理</strong><small>发布、激活与回滚</small></div>
            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" />
        </a>
        <a href="/config" class="delivery-row">
            <span class="delivery-icon"><MudIcon Icon="@Icons.Material.Filled.Tune" /></span>
            <div><strong>配置管理</strong><small>在线参数与公告</small></div>
            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" />
        </a>
    </section>
</div>

<section class="content-panel server-panel">
    <div class="panel-header server-panel-header">
        <div>
            <div class="panel-eyebrow">SERVER FLEET</div>
            <h2>服务器状态</h2>
        </div>
        <MudButton Href="/servers" Variant="Variant.Text" Color="Color.Primary"
                   EndIcon="@Icons.Material.Filled.ArrowForward">查看全部</MudButton>
    </div>
    @if (_servers.Any())
    {
        <MudTable Items="_servers" Dense="true" Hover="true" Elevation="0" Class="admin-table dashboard-table">
        <HeaderContent>
            <MudTh>进程ID</MudTh>
            <MudTh>名称</MudTh>
            <MudTh>状态</MudTh>
            <MudTh>在线人数</MudTh>
            <MudTh>CPU</MudTh>
            <MudTh>内存</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.ProcessId</MudTd>
            <MudTd><MudLink Href="@($"/servers/{context.ProcessId}")">@context.Name</MudLink></MudTd>
            <MudTd>
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small" Class="status-chip">
                    @GetStatusText(context.Status)
                </MudChip>
            </MudTd>
            <MudTd>@context.PlayerCount</MudTd>
            <MudTd>@context.CpuUsage.ToString("F1")%</MudTd>
            <MudTd>@FormatMemory(context.MemoryUsage) / @FormatMemory(context.MemoryTotal)</MudTd>
        </RowTemplate>
        </MudTable>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon"><MudIcon Icon="@Icons.Material.Filled.Dns" /></div>
            <div>
                <strong>暂无已管理的服务器</strong>
                <p>启动 Agent 或服务器进程后，运行状态会自动出现在这里。</p>
            </div>
            <MudButton Href="/servers" Variant="Variant.Outlined" Color="Color.Primary">前往服务器管理</MudButton>
        </div>
    }
</section>

@code {
    private int _totalServers;
    private int _runningServers;
    private int _onlinePlayers;
    private int _activeVersionCount;
    private int _totalAgents;
    private int _onlineAgents;
    private DateTime _lastUpdated = DateTime.Now;
    private List<ServerInfo> _servers = new();

    protected override void OnInitialized()
    {
        Notifier.OnServerStatusChanged += OnNotified;
        RefreshData();
    }

    private void RefreshData()
    {
        _servers = Notifier.GetServers();
        if (!_servers.Any())
        {
            _servers = MonitorService.GetServerStatus();
        }
        _totalServers = _servers.Count;
        _runningServers = _servers.Count(s => s.Status == ServerStatus.Running);
        _onlinePlayers = _servers.Sum(s => s.PlayerCount);
        _activeVersionCount = VersionService.GetAllVersions().Count(v => v.IsActive);
        var agents = ET.Tables.Instance.DTStartSceneConfig.Agents;
        _totalAgents = agents.Count;
        _onlineAgents = agents.Count(a => AgentService.IsAgentAlive(a.Process));
        _lastUpdated = DateTime.Now;
    }

    private void OnNotified()
    {
        InvokeAsync(() =>
        {
            RefreshData();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        Notifier.OnServerStatusChanged -= OnNotified;
    }

    private Color GetStatusColor(ServerStatus status) => status switch
    {
        ServerStatus.Running => Color.Success,
        ServerStatus.Starting => Color.Warning,
        ServerStatus.Stopping => Color.Warning,
        ServerStatus.Stopped => Color.Default,
        ServerStatus.Error => Color.Error,
        _ => Color.Default,
    };

    private string GetStatusText(ServerStatus status) => status switch
    {
        ServerStatus.Running => "运行中",
        ServerStatus.Starting => "启动中",
        ServerStatus.Stopping => "停止中",
        ServerStatus.Stopped => "已停止",
        ServerStatus.Error => "异常",
        _ => "未知",
    };

    private string FormatMemory(long bytes)
    {
        if (bytes <= 0) return "0 B";
        if (bytes < 1_000_000) return $"{bytes / 1_000.0:F1} KB";
        if (bytes < 1_000_000_000) return $"{bytes / 1_000_000.0:F0} MB";
        return $"{bytes / 1_000_000_000.0:F1} GB";
    }

    private string GetSystemHealthText()
    {
        if (_totalServers == 0) return "等待服务器接入";
        if (_runningServers == _totalServers && _onlineAgents == _totalAgents) return "全部系统正常";
        if (_runningServers > 0) return "部分服务需关注";
        return "服务当前离线";
    }

    private string GetSystemHealthClass()
    {
        if (_totalServers > 0 && _runningServers == _totalServers && _onlineAgents == _totalAgents) return "health-good";
        if (_runningServers > 0) return "health-warning";
        return "health-neutral";
    }
}
