@page "/servers/scenes"
@inject ServerMonitorService MonitorService
@inject ServerMonitorNotifier Notifier
@inject ProcessManagerService ProcessManager
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Scene 监控 - 游戏管理后台</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Scene 监控</MudText>

@* 统计概览 *@
<MudGrid Class="mb-4">
    <MudItem xs="6" sm="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">总 Scene 数</MudText>
                <MudText Typo="Typo.h5">@_scenes.Count</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">总玩家数</MudText>
                <MudText Typo="Typo.h5">@_scenes.Sum(s => s.PlayerCount)</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Zone 数量</MudText>
                <MudText Typo="Typo.h5">@_scenes.Select(s => s.Zone).Distinct().Count()</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">场景类型数</MudText>
                <MudText Typo="Typo.h5">@_scenes.Select(s => s.SceneType).Distinct().Count()</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@* 视图切换 *@
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h6">Scene 列表</MudText>
    <MudSpacer />
    <MudToggleIconButton @bind-Toggled="_groupByZone"
                         Icon="@Icons.Material.Filled.ViewList" ToggledIcon="@Icons.Material.Filled.ViewModule" />
    <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="RefreshData" />
</MudStack>

@if (!_scenes.Any())
{
    <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info">
        暂无 Scene 数据。ET 进程未连接或未响应。
    </MudAlert>
}
else if (_groupByZone)
{
    @foreach (var group in _scenes.GroupBy(s => s.Zone).OrderBy(g => g.Key))
    {
        <MudExpansionPanels Class="mb-2">
            <MudExpansionPanel>
                <TitleContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.subtitle1"><strong>Zone @group.Key</strong></MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@group.Count() 个场景</MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">@group.Sum(s => s.PlayerCount) 玩家</MudChip>
                    </MudStack>
                </TitleContent>
                <ChildContent>
                    <MudTable Items="group.ToList()" Dense="true" Hover="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>类型</MudTh>
                            <MudTh>名称</MudTh>
                            <MudTh>内网地址</MudTh>
                            <MudTh>外网地址</MudTh>
                            <MudTh>玩家数</MudTh>
                            <MudTh>Fiber</MudTh>
                            <MudTh>进程</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Id</MudTd>
                            <MudTd><MudChip T="string" Size="Size.Small" Color="@GetSceneColor(context.SceneType)">@context.SceneType</MudChip></MudTd>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>@context.InnerAddress</MudTd>
                            <MudTd>@context.OuterAddress</MudTd>
                            <MudTd>@context.PlayerCount</MudTd>
                            <MudTd>@context.FiberId</MudTd>
                            <MudTd><MudLink Href="@($"/servers/{context.ProcessId}")">@context.ProcessId</MudLink></MudTd>
                        </RowTemplate>
                    </MudTable>
                </ChildContent>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }
}
else
{
    <MudTable Items="_scenes" Dense="true" Hover="true" Elevation="2" Filter="FilterFunc">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchString" Placeholder="搜索 Scene..." Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                          Immediate="true" Class="mt-0" />
            <MudSpacer />
            <MudSelect @bind-Value="_filterSceneType" Label="场景类型" Variant="Variant.Outlined" Dense="true"
                       Margin="Margin.Dense" Style="width:150px;">
                <MudSelectItem T="string" Value="@("")">全部</MudSelectItem>
                @foreach (var type in _scenes.Select(s => s.SceneType).Distinct().OrderBy(t => t))
                {
                    <MudSelectItem T="string" Value="@type">@type</MudSelectItem>
                }
            </MudSelect>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<SceneInfo, object>(x => x.Id)">ID</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<SceneInfo, object>(x => x.Zone)">Zone</MudTableSortLabel></MudTh>
            <MudTh>类型</MudTh>
            <MudTh>名称</MudTh>
            <MudTh>内网地址</MudTh>
            <MudTh>外网地址</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<SceneInfo, object>(x => x.PlayerCount)">玩家数</MudTableSortLabel></MudTh>
            <MudTh>Fiber</MudTh>
            <MudTh>进程</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Id</MudTd>
            <MudTd>@context.Zone</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@GetSceneColor(context.SceneType)">@context.SceneType</MudChip></MudTd>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.InnerAddress</MudTd>
            <MudTd>@context.OuterAddress</MudTd>
            <MudTd>@context.PlayerCount</MudTd>
            <MudTd>@context.FiberId</MudTd>
            <MudTd><MudLink Href="@($"/servers/{context.ProcessId}")">@context.ProcessId</MudLink></MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>暂无匹配的 Scene 数据</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
}

@code {
    private string _searchString = "";
    private string _filterSceneType = "";
    private bool _groupByZone = true;

    private List<SceneInfo> _scenes = new();

    protected override void OnInitialized()
    {
        Notifier.OnScenesChanged += OnNotified;
        _scenes = Notifier.GetAllScenes();
    }

    private async Task RefreshData()
    {
        _scenes = await MonitorService.GetAllScenesAsync();
        if (_scenes.Any())
        {
            Snackbar.Add($"已刷新，获取到 {_scenes.Count} 个 Scene", Severity.Info);
        }
    }

    private void OnNotified()
    {
        InvokeAsync(() =>
        {
            _scenes = Notifier.GetAllScenes();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        Notifier.OnScenesChanged -= OnNotified;
    }

    private bool FilterFunc(SceneInfo scene)
    {
        if (!string.IsNullOrEmpty(_filterSceneType) && scene.SceneType != _filterSceneType) return false;
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        return scene.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || scene.SceneType.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || scene.Id.ToString().Contains(_searchString);
    }

    private Color GetSceneColor(string sceneType) => sceneType switch
    {
        "Gate" => Color.Info,
        "Map" => Color.Success,
        "Location" => Color.Warning,
        "Realm" => Color.Tertiary,
        "Chat" => Color.Secondary,
        "Robot" => Color.Default,
        _ => Color.Default,
    };
}
