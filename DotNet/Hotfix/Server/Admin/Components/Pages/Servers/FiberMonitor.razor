@page "/servers/fibers"
@inject ServerMonitorService MonitorService
@inject ServerMonitorNotifier Notifier
@inject ProcessManagerService ProcessManager
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Fiber 监控 - 游戏管理后台</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Fiber 监控</MudText>

@* 统计概览 *@
<MudGrid Class="mb-4">
    <MudItem xs="6" sm="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">总 Fiber 数</MudText>
                <MudText Typo="Typo.h5">@_fibers.Count</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Entity 总数</MudText>
                <MudText Typo="Typo.h5">@_fibers.Sum(f => f.EntityCount)</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Main 线程</MudText>
                <MudText Typo="Typo.h5">@_fibers.Count(f => f.SchedulerType == "Main")</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">ThreadPool</MudText>
                <MudText Typo="Typo.h5">@_fibers.Count(f => f.SchedulerType == "ThreadPool")</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<MudTable Items="_filteredFibers" Dense="true" Hover="true" Elevation="2" Filter="FilterFunc" Loading="_loading">
    <ToolBarContent>
        <MudTextField @bind-Value="_searchString" Placeholder="搜索 Fiber..." Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                      Immediate="true" Class="mt-0" />
        <MudSpacer />
        <MudSelect @bind-Value="_filterScheduler" Label="调度器" Variant="Variant.Outlined" Dense="true"
                   Margin="Margin.Dense" Class="ml-2" Style="width:150px;">
            <MudSelectItem T="string" Value="@("")">全部</MudSelectItem>
            <MudSelectItem T="string" Value="@("Main")">Main</MudSelectItem>
            <MudSelectItem T="string" Value="@("Thread")">Thread</MudSelectItem>
            <MudSelectItem T="string" Value="@("ThreadPool")">ThreadPool</MudSelectItem>
        </MudSelect>
        <MudSelect @bind-Value="_filterSceneType" Label="场景类型" Variant="Variant.Outlined" Dense="true"
                   Margin="Margin.Dense" Class="ml-2" Style="width:150px;">
            <MudSelectItem T="string" Value="@("")">全部</MudSelectItem>
            @foreach (var type in _fibers.Select(f => f.SceneType).Distinct().OrderBy(t => t))
            {
                <MudSelectItem T="string" Value="@type">@type</MudSelectItem>
            }
        </MudSelect>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="RefreshData" Class="ml-2" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<FiberInfo, object>(x => x.Id)">ID</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<FiberInfo, object>(x => x.Zone)">Zone</MudTableSortLabel></MudTh>
        <MudTh>场景类型</MudTh>
        <MudTh>名称</MudTh>
        <MudTh>调度器</MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<FiberInfo, object>(x => x.EntityCount)">Entity 数</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<FiberInfo, object>(x => x.ProcessId)">进程ID</MudTableSortLabel></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Id</MudTd>
        <MudTd>@context.Zone</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@GetSceneColor(context.SceneType)">@context.SceneType</MudChip></MudTd>
        <MudTd>@context.Name</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                     Color="@(context.SchedulerType == "Main" ? Color.Primary : Color.Default)">
                @context.SchedulerType
            </MudChip>
        </MudTd>
        <MudTd>@context.EntityCount</MudTd>
        <MudTd>
            <MudLink Href="@($"/servers/{context.ProcessId}")">@context.ProcessId</MudLink>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="py-4">
            <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" />
            <MudText>暂无 Fiber 数据</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">ET 进程未连接或未响应，无法获取 Fiber 信息</MudText>
        </MudStack>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new[] { 25, 50, 100 }" />
    </PagerContent>
</MudTable>

@code {
    private bool _loading;
    private string _searchString = "";
    private string _filterScheduler = "";
    private string _filterSceneType = "";

    private List<FiberInfo> _fibers = new();
    private IEnumerable<FiberInfo> _filteredFibers => _fibers
        .Where(f => string.IsNullOrEmpty(_filterScheduler) || f.SchedulerType == _filterScheduler)
        .Where(f => string.IsNullOrEmpty(_filterSceneType) || f.SceneType == _filterSceneType);

    protected override void OnInitialized()
    {
        Notifier.OnFibersChanged += OnNotified;
        _fibers = Notifier.GetAllFibers();
    }

    private async Task RefreshData()
    {
        _loading = true;
        StateHasChanged();

        var newFibers = new List<FiberInfo>();
        var servers = ProcessManager.GetAllServers();
        foreach (var server in servers.Where(s => s.Status == ServerStatus.Running))
        {
            var fibers = await MonitorService.GetFibersAsync(server.ProcessId);
            newFibers.AddRange(fibers);
        }
        _fibers = newFibers;

        _loading = false;
        Snackbar.Add($"已刷新，获取到 {_fibers.Count} 个 Fiber", Severity.Info);
    }

    private void OnNotified()
    {
        InvokeAsync(() =>
        {
            _fibers = Notifier.GetAllFibers();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        Notifier.OnFibersChanged -= OnNotified;
    }

    private bool FilterFunc(FiberInfo fiber)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        return fiber.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || fiber.SceneType.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || fiber.Id.ToString().Contains(_searchString);
    }

    private Color GetSceneColor(string sceneType) => sceneType switch
    {
        "Main" => Color.Primary,
        "Gate" => Color.Info,
        "Map" => Color.Success,
        "Location" => Color.Warning,
        "Robot" => Color.Secondary,
        "Realm" => Color.Tertiary,
        _ => Color.Default,
    };
}
